generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum SubscriptionTier {
  trial
  starter
  pro
  read_only
  suspended
}

enum SubscriptionStatus {
  active
  grace
  canceled
}

enum CourierName {
  steadfast
  pathao
  redx
}

enum CourierAccountStatus {
  active
  invalid
  rate_limited
}

enum RiskBand {
  green
  yellow
  red
}

enum OrderStatus {
  draft
  placed
  pending_approval
  approved
  shipped
  delivered
  returned
  canceled
  rejected
}

enum OrderSource {
  ai
  manual
}

enum AiToneProfile {
  formal_apu
  casual_apu
  friendly_bhai
}

enum StockStatus {
  in_stock
  low_stock
  out_of_stock
}

enum ConversationChannel {
  messenger
  instagram
  whatsapp
}

enum ConversationState {
  new_inquiry
  product_discussion
  order_collection
  order_confirmed
  human_handoff
  closed
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageSource {
  customer
  ai
  seller
}

enum HandoffReason {
  low_confidence
  catalog_miss
  abuse
  discount_request
  off_topic
  llm_error
  manual
}

enum ConsignmentEventSource {
  webhook
  poll
}

enum PaymentGateway {
  sslcommerz
  shurjopay
}

enum SubscriptionPlan {
  starter
  pro
}

enum SubscriptionLifecycleStatus {
  trial
  trial_expired
  read_only
  active
  grace
  canceled
  suspended
}

enum MatchStatus {
  matched
  unmatched
  disputed
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone              String?            @unique @db.VarChar(15)
  email              String?            @unique
  name               String
  passwordHash       String?
  createdAt          DateTime           @default(now()) @db.Timestamptz()
  updatedAt          DateTime           @updatedAt @db.Timestamptz()
  lastLoginAt        DateTime?          @db.Timestamptz()
  subscriptionTier   SubscriptionTier   @default(trial)
  subscriptionStatus SubscriptionStatus @default(active)
  // Platform admin can access /platform-setup. Auto-promoted at register time
  // when no admin exists yet (and the migration promotes the earliest user).
  isAdmin            Boolean            @default(false)
  // Platform OWNER — the BoxBazar operator. One per deployment, identified by
  // the OWNER_EMAIL env var. Can list every user + impersonate them via the
  // /owner panel. Strict superset of isAdmin (owner is always also admin).
  isOwner            Boolean            @default(false)
  // 4-character public user ID: 2 letters (A-Z minus I/O) + 2 digits (2-9
  // minus 0/1) at random positions, e.g. "K3X7", "4A2B". Surfaced in the
  // owner panel and ops UIs. Nullable because the migration backfills.
  publicId           String?            @unique @db.VarChar(4)
  // Two-factor authentication via email-delivered one-time codes.
  mfaEnabled         Boolean            @default(false)
  mfaEnrolledAt      DateTime?          @db.Timestamptz()

  stores             Store[]
  customers          Customer[]
  orders             Order[]
  subscription       Subscription?
  chatParseAttempts  ChatParseAttempt[]
  payoutBatches      PayoutBatch[]
  refreshTokens      RefreshToken[]
  mfaCodes           MfaCode[]

  @@map("users")
}

enum MfaCodePurpose {
  enroll
  challenge
  owner_login
}

model MfaCode {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String         @db.Uuid
  codeHash    String
  purpose     MfaCodePurpose
  expiresAt   DateTime       @db.Timestamptz()
  consumedAt  DateTime?      @db.Timestamptz()
  attempts    Int            @default(0)
  createdAt   DateTime       @default(now()) @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("mfa_codes")
}

model OtpCode {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone     String   @db.VarChar(15)
  codeHash  String
  expiresAt DateTime @db.Timestamptz()
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz()

  @@index([phone])
  @@map("otp_codes")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String   @unique
  expiresAt DateTime @db.Timestamptz()
  createdAt DateTime @default(now()) @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Store {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  name      String
  category  String
  fbPageUrl String?
  createdAt DateTime @default(now()) @db.Timestamptz()

  // ─ AI receptionist config ─
  fbPageId                        String?       @unique @db.VarChar(64)
  fbPageName                      String?
  fbPageAccessTokenEncrypted      String?
  fbConnectedAt                   DateTime?     @db.Timestamptz()
  aiToneProfile                   AiToneProfile @default(formal_apu)
  aiEnabled                       Boolean       @default(false)
  aiDisclosureFooterEnabled       Boolean       @default(false)
  pickupAddress                   Json?
  deliveryChargeInsideDhakaCents  BigInt        @default(0)
  deliveryChargeOutsideDhakaCents BigInt        @default(0)
  workingHoursStart               String?       @db.VarChar(5)
  workingHoursEnd                 String?       @db.VarChar(5)
  returnPolicyText                String?       @db.Text

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courierAccounts  CourierAccount[]
  orders           Order[]
  products         Product[]
  customers        Customer[]
  conversations    Conversation[]

  @@map("stores")
}

model Product {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId         String      @db.Uuid
  name            String
  description     String?     @db.Text
  basePriceCents  BigInt
  floorPriceCents BigInt
  variants        Json        @default("[]")
  stockStatus     StockStatus @default(in_stock)
  photoUrl        String?
  keywords        String[]    @default([])
  active          Boolean     @default(true)
  createdAt       DateTime    @default(now()) @db.Timestamptz()
  updatedAt       DateTime    @updatedAt @db.Timestamptz()

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@map("products")
}

model CourierAccount {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId              String               @db.Uuid
  courier              CourierName
  encryptedCredentials Json
  status               CourierAccountStatus @default(active)
  lastBalanceCheckedAt DateTime?            @db.Timestamptz()
  lastBalanceAmount    Int?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, courier])
  @@map("courier_accounts")
}

model Customer {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @db.Uuid
  storeId        String?  @db.Uuid
  phone          String?  @db.VarChar(15)
  name           String
  messengerPsid  String?  @db.VarChar(100)
  addressHistory Json     @default("[]")
  createdAt      DateTime @default(now()) @db.Timestamptz()

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  store         Store?         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  fraudSignals  FraudSignal[]
  orders        Order[]
  conversations Conversation[]

  @@unique([storeId, messengerPsid])
  @@index([phone])
  @@map("customers")
}

model Conversation {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId        String              @db.Uuid
  customerId     String              @db.Uuid
  channel        ConversationChannel @default(messenger)
  state          ConversationState   @default(new_inquiry)
  aiEnabled      Boolean             @default(true)
  // Seller-flagged: include this conversation as a few-shot example in the
  // AI's system prompt. Picks the seller's own voice / tone / register so
  // the AI starts mimicking how THEY actually talk to their customers.
  useAsExample   Boolean             @default(false)
  lastMessageAt  DateTime?           @db.Timestamptz()
  lastAiActionAt DateTime?           @db.Timestamptz()
  createdAt      DateTime            @default(now()) @db.Timestamptz()
  updatedAt      DateTime            @updatedAt @db.Timestamptz()

  store        Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer     Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messages     Message[]
  handoffFlags AiHandoffFlag[]
  orders       Order[]

  @@unique([storeId, customerId, channel])
  @@index([storeId, lastMessageAt])
  @@map("conversations")
}

model Message {
  id                     String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId         String           @db.Uuid
  direction              MessageDirection
  source                 MessageSource
  text                   String?          @db.Text
  attachments            Json             @default("[]")
  aiIntentClassification Json?
  aiConfidence           Float?
  aiRawPayload           Json?
  metaMessageId          String?          @db.VarChar(255)
  createdAt              DateTime         @default(now()) @db.Timestamptz()

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([metaMessageId])
  @@map("messages")
}

model AiHandoffFlag {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId   String        @db.Uuid
  reason           HandoffReason
  detail           String?       @db.Text
  resolved         Boolean       @default(false)
  resolvedByUserId String?       @db.Uuid
  resolvedAt       DateTime?     @db.Timestamptz()
  createdAt        DateTime      @default(now()) @db.Timestamptz()

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([resolved])
  @@map("ai_handoff_flags")
}

model FraudSignal {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId       String      @db.Uuid
  courier          CourierName
  totalOrders      Int
  successfulOrders Int
  canceledOrders   Int
  riskScore        Int
  riskBand         RiskBand
  rawPayload       Json
  fetchedAt        DateTime    @db.Timestamptz()
  expiresAt        DateTime    @db.Timestamptz()

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("fraud_signals")
}

model Order {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String      @db.Uuid
  storeId          String      @db.Uuid
  customerId       String      @db.Uuid
  conversationId   String?     @db.Uuid
  source           OrderSource @default(manual)
  status           OrderStatus @default(draft)
  subtotalCents    BigInt
  deliveryCents    BigInt
  codCents         BigInt
  items            Json
  notes            String?
  sourceChat       String?     @db.Text
  parsedConfidence Json?
  aiExtractedData  Json?
  rejectionReason  String?
  approvedAt       DateTime?   @db.Timestamptz()
  approvedByUserId String?     @db.Uuid
  createdAt        DateTime    @default(now()) @db.Timestamptz()
  updatedAt        DateTime    @updatedAt @db.Timestamptz()

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  consignment  Consignment?

  @@index([storeId, status])
  @@map("orders")
}

model Consignment {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId              String   @unique @db.Uuid
  courier              CourierName
  consignmentId        String   @db.VarChar(100)
  trackingCode         String   @db.VarChar(100)
  invoiceId            String   @unique @db.VarChar(100)
  currentStatus        String   @db.VarChar(100)
  labelPdfUrl          String?
  rawCreationResponse  Json
  createdAt            DateTime @default(now()) @db.Timestamptz()

  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courierEvents  CourierEvent[]
  payoutLineItems PayoutLineItem[]

  @@map("consignments")
}

model CourierEvent {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  consignmentId  String                 @db.Uuid
  status         String                 @db.VarChar(100)
  occurredAt     DateTime               @db.Timestamptz()
  rawPayload     Json
  source         ConsignmentEventSource

  consignment Consignment @relation(fields: [consignmentId], references: [id], onDelete: Cascade)

  @@map("courier_events")
}

model PayoutBatch {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String      @db.Uuid
  courier          CourierName
  payoutId         String      @db.VarChar(100)
  totalAmountCents BigInt
  bankReference    String?
  paidAt           DateTime    @db.Timestamptz()
  rawPayload       Json

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  payoutLineItems PayoutLineItem[]

  @@map("payout_batches")
}

model PayoutLineItem {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payoutBatchId   String      @db.Uuid
  consignmentId   String?     @db.Uuid
  amountCents     BigInt
  matchStatus     MatchStatus @default(unmatched)
  rawPayload      Json

  payoutBatch  PayoutBatch  @relation(fields: [payoutBatchId], references: [id], onDelete: Cascade)
  consignment  Consignment? @relation(fields: [consignmentId], references: [id], onDelete: SetNull)

  @@map("payout_line_items")
}

model Subscription {
  id                    String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String                      @unique @db.Uuid
  status                SubscriptionLifecycleStatus @default(trial)
  plan                  SubscriptionPlan?
  trialStartedAt        DateTime                    @db.Timestamptz()
  trialEndsAt           DateTime                    @db.Timestamptz()
  trialExtensionCount   Int                         @default(0)
  readOnlyUntil         DateTime?                   @db.Timestamptz()
  suspendedAt           DateTime?                   @db.Timestamptz()
  dataPurgeAt           DateTime?                   @db.Timestamptz()
  subscriptionStartedAt DateTime?                   @db.Timestamptz()
  currentPeriodEnd      DateTime?                   @db.Timestamptz()
  canceledAt            DateTime?                   @db.Timestamptz()
  paymentGateway        PaymentGateway?
  gatewaySubscriptionId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model ChatParseAttempt {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @db.Uuid
  rawText       String   @db.Text
  extractedData Json
  confidence    Json
  userEdits     Json?
  createdAt     DateTime @default(now()) @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_parse_attempts")
}

// Single-row table holding platform-level API credentials editable from the
// dashboard ("Platform API keys" page). The lone row is keyed by the literal
// id 'singleton'. Sensitive values are stored in `encryptedSecrets` (AES-GCM
// JSON blob) so they never appear in plain text; public/non-secret config
// (App ID, Graph version, public webhook URL, model name) sits next to it.
model PlatformConfig {
  id               String   @id @default("singleton")
  metaAppId        String?
  metaGraphVersion String?
  publicWebhookUrl String?
  geminiModel      String?
  aiProvider       String?
  bulkSmsSenderId  String?
  encryptedSecrets String?  @db.Text
  updatedAt        DateTime @updatedAt @db.Timestamptz()
  createdAt        DateTime @default(now()) @db.Timestamptz()

  @@map("platform_config")
}
