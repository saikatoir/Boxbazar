{
  "name": "@fcommerce/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate --schema=../../packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=../../packages/db/prisma/schema.prisma"
  },
  "dependencies": {
    "fastify": "^4.27.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/jwt": "^8.0.1",
    "@fastify/helmet": "^11.1.1",
    "@prisma/client": "^5.15.0",
    "zod": "^3.23.8",
    "bullmq": "^5.8.0",
    "ioredis": "^5.4.1",
    "fastify-plugin": "^4.5.1",
    "pino": "^9.2.0",
    "bcryptjs": "^2.4.3",
    "pdf-lib": "^1.17.1",
    "bwip-js": "^4.4.0",
    "@fcommerce/db": "workspace:*",
    "@fcommerce/courier-sdk": "workspace:*",
    "@fcommerce/shared": "workspace:*",
    "@fcommerce/ai-engine": "workspace:*",
    "@fcommerce/meta-sdk": "workspace:*"
  },
  "devDependencies": {
    "prisma": "^5.15.0",
    "typescript": "^5.4.5",
    "tsx": "^4.16.0",
    "@types/node": "^20.14.0",
    "@types/bcryptjs": "^2.4.6"
  }
}
